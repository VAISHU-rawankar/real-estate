# ================================================================
# REAL ESTATE PLATFORM — ENVIRONMENT VARIABLES
# Copy to .env and fill in all values before starting
# ================================================================

# ----- App -----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ----- MongoDB -----
MONGO_URI=mongodb://localhost:27017/realestate

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- JWT (generate with: openssl rand -base64 64) -----
JWT_ACCESS_SECRET=your-very-long-and-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-very-long-and-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ----- AWS -----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=realestate-media-bucket
CLOUDFRONT_DOMAIN=https://dxxxxxxxxx.cloudfront.net

# ----- Razorpay -----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
FEATURED_LISTING_PRICE=99900

# ----- Google -----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_MAPS_API_KEY=your-maps-api-key
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ----- Email (SendGrid preferred) -----
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
EMAIL_FROM=noreply@yourrealestate.com
EMAIL_FROM_NAME=YourBrand Real Estate

# ----- SMS (Twilio) -----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ----- Or MSG91 (Indian SMS) -----
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=YRBRND
MSG91_TEMPLATE_ID=your-otp-template-id

# ----- Admin Seed -----
ADMIN_EMAIL=admin@yourrealestate.com
ADMIN_PASSWORD=StrongPassword123!
ADMIN_NAME=Admin User

# ----- Sentry (Error Tracking) -----
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ----- Frontend (prefix with VITE_) -----
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_MAPS_KEY=your-maps-api-key
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
VITE_SENTRY_DSN=your-frontend-sentry-dsn
